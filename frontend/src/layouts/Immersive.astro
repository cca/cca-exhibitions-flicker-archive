---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="/fonts/lineto-brown-regular.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title} — CCA Exhibitions Archive</title>
  </head>
  <body class="immersive-body">
    <a href="/" class="immersive-wordmark">
      <img src="/logo-cca-dynamic.svg" alt="CCA" class="immersive-logo" />
    </a>
    <slot />
  </body>
</html>

<style>
  .immersive-body {
    background: var(--immersive);
    color: #fff;
    overflow: hidden;
    height: 100dvh;
    margin: 0;
    padding: 0;
  }

  .immersive-wordmark {
    position: fixed;
    top: 1.25rem;
    left: clamp(1rem, 3vw, 2rem);
    text-decoration: none;
    z-index: 50;
    transition: opacity 200ms var(--ease);
    opacity: 0.35;
  }

  .immersive-wordmark:hover {
    opacity: 0.6;
  }

  .immersive-logo {
    height: 1.6rem;
    width: auto;
    filter: brightness(0) invert(1);
  }
</style>
