---
import Base from "../layouts/Base.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import EntryPoints from "../components/EntryPoints.astro";
import RecentStrip from "../components/RecentStrip.astro";
import { getAllAlbums, getRecentAlbums } from "../lib/data";

const allAlbums = await getAllAlbums();
const recentAlbums = await getRecentAlbums(8);
---

<Base title="Home">
  <HeroCarousel albums={allAlbums} />
  <EntryPoints />
  <RecentStrip albums={recentAlbums} />
</Base>
