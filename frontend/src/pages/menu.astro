---
import "../styles/global.css";

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/timeline", label: "Timeline" },
  { href: "/slideshow", label: "Slideshow" },
  { href: "/search", label: "Search" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="/fonts/lineto-brown-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/lineto-brown-bold.woff2" as="font" type="font/woff2" crossorigin />
    <title>Menu — CCA Exhibitions Archive</title>
  </head>
  <body>
    <header class="menu-header">
      <nav class="container menu-topbar">
        <a href="/" class="site-wordmark">
          <img src="/logo-cca-lettermark.svg" alt="CCA" class="wordmark-logo" />
          <span class="wordmark-divider"></span>
          <span class="wordmark-label">Exhibitions Archive</span>
        </a>
        <a href="javascript:history.back()" class="menu-close">Close</a>
      </nav>
    </header>
    <main class="menu-body">
      <nav class="menu-links">
        {navLinks.map((link) => (
          <a href={link.href} class="menu-link">{link.label}</a>
        ))}
      </nav>
    </main>
  </body>
</html>

<style>
  .menu-header {
    display: flex;
    align-items: center;
    min-height: 3.5rem;
    border-bottom: 1px solid var(--border);
  }

  .menu-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .site-wordmark {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--ink);
    text-decoration: none;
    transition: opacity 200ms var(--ease);
  }

  .site-wordmark:hover {
    opacity: 0.75;
    color: var(--ink);
  }

  .wordmark-logo {
    height: 1.15rem;
    width: auto;
    display: block;
  }

  .wordmark-divider {
    width: 1px;
    align-self: stretch;
    background: var(--ink-faint);
  }

  .wordmark-label {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--ink-light);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
  }

  .menu-close {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--ink-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: color 200ms var(--ease);
  }

  .menu-close:hover {
    color: var(--ink);
  }

  .menu-body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - 3.5rem);
    padding: 0 var(--page-pad);
  }

  .menu-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .menu-link {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 8vw, 3.5rem);
    color: var(--ink);
    text-decoration: none;
    line-height: 1.1;
    transition: color 200ms var(--ease);
  }

  .menu-link:hover {
    color: var(--accent);
  }
</style>
