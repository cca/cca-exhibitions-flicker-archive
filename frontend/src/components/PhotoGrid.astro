---
import type { Photo } from "../lib/data";
import PhotoCard from "./PhotoCard.astro";

interface Props {
  photos: Photo[];
  albumSlug: string;
}

const { photos, albumSlug } = Astro.props;
---

<section class="photo-grid-section">
  <div class="section-header">
    <h2 class="section-heading">Photographs</h2>
    <span class="section-count">{photos.length}</span>
  </div>
  {
    photos.length > 0 ? (
      <div class="photo-grid">
        {photos.map((photo) => (
          <PhotoCard photo={photo} albumSlug={albumSlug} />
        ))}
      </div>
    ) : (
      <p class="empty">No photographs in this album.</p>
    )
  }
</section>

<style>
  .photo-grid-section {
    margin-top: 0.5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 400;
    font-style: italic;
    color: var(--text);
  }

  .section-count {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    padding: 0.15em 0.5em;
    border: 1px solid var(--border);
    border-radius: 3px;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 0.6rem;
  }

  @media (min-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
      gap: 0.75rem;
    }
  }

  @media (min-width: 1024px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    }
  }
</style>
