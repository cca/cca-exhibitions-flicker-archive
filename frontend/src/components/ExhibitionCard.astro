---
import type { Album } from "../lib/data";

interface Props {
  album: Album;
}

const { album } = Astro.props;

const dateRange =
  album.opening_date && album.closing_date
    ? `${album.opening_date} — ${album.closing_date}`
    : album.opening_date || album.closing_date || "";
---

<a href={`/albums/${album.slug}`} class="card">
  <div class="card__frame">
    {
      album.cover_image ? (
        <img src={album.cover_thumbnail || album.cover_image} alt={album.exhibition_title || album.album_title} loading="lazy" decoding="async" width="400" height="267" />
      ) : (
        <div class="card__empty">
          <span>No image</span>
        </div>
      )
    }
    <div class="card__overlay">
      <span class="card__view">View Exhibition &rarr;</span>
    </div>
  </div>
  <div class="card__body">
    <h2 class="card__title">{album.exhibition_title || album.album_title}</h2>
    {album.venue && <p class="card__venue">{album.venue}</p>}
    <div class="card__footer">
      {dateRange && <span class="card__date">{dateRange}</span>}
      <span class="card__count">{album.photos.length} photos</span>
    </div>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: var(--text);
    transition: all 300ms var(--ease);
  }

  .card:hover {
    border-color: var(--border-hover);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.03),
      0 8px 32px rgba(0, 0, 0, 0.3);
    transform: translateY(-3px);
  }

  .card__frame {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #080808;
    position: relative;
  }

  .card__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms var(--ease), filter 500ms var(--ease);
    filter: brightness(0.92) saturate(0.9);
  }

  .card:hover .card__frame img {
    transform: scale(1.04);
    filter: brightness(1) saturate(1);
  }

  .card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.5) 0%,
      transparent 50%
    );
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 0.75rem;
    opacity: 0;
    transition: opacity 300ms var(--ease);
  }

  .card:hover .card__overlay {
    opacity: 1;
  }

  .card__view {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.3em 0.7em;
    border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .card__empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    font-size: 0.8rem;
    font-style: italic;
    font-family: var(--font-display);
  }

  .card__body {
    padding: 0.9rem 1rem 1rem;
  }

  .card__title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    font-style: italic;
    line-height: 1.3;
    margin-bottom: 0.25rem;
    color: var(--text);
  }

  .card__venue {
    font-size: 0.78rem;
    color: var(--text-secondary);
    margin-bottom: 0.6rem;
    letter-spacing: 0.01em;
  }

  .card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.55rem;
    border-top: 1px solid var(--border);
  }

  .card__date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: -0.01em;
  }

  .card__count {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
  }
</style>
