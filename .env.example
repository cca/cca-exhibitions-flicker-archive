FLICKR_API_KEY=your_flickr_api_key
FLICKR_API_SECRET=your_flickr_api_secret
FLICKR_USER_ID=your_flickr_user_id
LLM_MODEL=anthropic:claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Internet Archive (for --upload-ia)
IA_ACCESS_KEY=your_ia_access_key
IA_SECRET_KEY=your_ia_secret_key

# IIIF base URL for frontend image serving
# Production (IA):  https://iiif.archive.org/image/iiif
# Local dev:        http://localhost:8182/iiif/3
PUBLIC_IIIF_BASE_URL=https://iiif.archive.org/image/iiif

# Google Cloud Storage (for --upload-gcs / cca-archive sync --gcs)
GCS_BUCKET=your-gcs-bucket-name
GCS_CREDENTIALS_FILE=/path/to/service-account.json  # optional; omit to use ADC

# Frontend image base URL for GCS mode (used by docker-compose.gcs.yml)
PUBLIC_GCS_BASE_URL=https://storage.googleapis.com/your-gcs-bucket-name

# URL base for pre-optimized web images on GCS (e.g. https://storage.googleapis.com/bucket)
PUBLIC_GCS_IMAGE_BASE_URL=

# URL base for local optimized images (relative path, for offline/local builds)
# Set to /web for docker-compose.local-optimized.yml and offline flash-drive exports
PUBLIC_LOCAL_IMAGE_BASE=
